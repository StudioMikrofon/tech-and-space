		<g style="font-size:10px;fill:#000000;fill-opacity:1;fill-rule:nonzero;stroke:none;font-family:Arial, sans-serif;">
			<g transform="translate(345,380)" id="maintext">
				<text transform="matrix(1,0,0,-1,0,338)"><!--
				--><tspan x="0" y="0" ><tspan style="font-weight:bold;">Emissions:</tspan> include benzene, volatile organic compounds</tspan><!--
				--><tspan x="0" y="12">and 170+ toxic chemicals in fracking fuid</tspan><!--
				--><tspan x="0" y="30"><tspan style="font-weight:bold;">Possible health efects:</tspan> afect the immune system, sensory</tspan><!--
				--><tspan x="0" y="42">organs, liver and kidney; cancers, neurotoxicity, reproductive </tspan><!--
				--><tspan x="0" y="54">and developmental toxicity</tspan><!--
				--></text>
				<text transform="matrix(1,0,0,-1,0,256)"><!--
				--><tspan x="0" y="0" ><tspan style="font-weight:bold;">Emissions:</tspan> include benzene, polycyclic aromatic hydrocarbons</tspan><!--
				--><tspan x="0" y="12">and styrene</tspan><!--
				--><tspan x="0" y="30"><tspan style="font-weight:bold;">Possible health efects:</tspan> cancers, neurotoxicity, reproductive</tspan><!--
				--><tspan x="0" y="44">toxicity, low birthweight, eye and skin irritation</tspan><!--
				--><tspan x="0" y="54"></tspan><!--
				--></text>
				<text transform="matrix(1,0,0,-1,0,174)"><!--
				--><tspan x="0" y="0" ><tspan style="font-weight:bold;">Emissions:</tspan>  include heavy metals, persistent organic pollutants, </tspan><!--
				--><tspan x="0" y="12">carcinogens, endocrine-disrupting chemicals, microplastics</tspan><!--
				--><tspan x="0" y="30"><tspan style="font-weight:bold;">Possible health efects:</tspan> afect renal, cardiovascular, gastro-</tspan><!--
				--><tspan x="0" y="42">intestinal, neurological, reproductive, and respiratory systems; </tspan><!--
				--><tspan x="0" y="54">cancers, diabetes, and developmental toxicity</tspan><!--
				--></text>
				<text transform="matrix(1,0,0,-1,0,92)"><!--
				--><tspan x="0" y="0" ><tspan style="font-weight:bold;">Emissions:</tspan> include heavy metals, dioxins and furans, polycyclic </tspan><!--
				--><tspan x="0" y="12">aromatic hydrocarbons, toxic recycling</tspan><!--
				--><tspan x="0" y="30"><tspan style="font-weight:bold;">Possible health efects:</tspan> cancers, neurological damages, </tspan><!--
				--><tspan x="0" y="42">damages to immune, reproductive, nervous, and endocrine </tspan><!--
				--><tspan x="0" y="54">systems</tspan><!--
				--></text>
				<text transform="matrix(1,0,0,-1,0,0)"><!--
				--><tspan x="0" y="0" ><tspan style="font-weight:bold;">Emissions: </tspan>microplastics (e.g., tire dust, textile fibers) and toxic </tspan><!--
				--><tspan x="0" y="12">additives, including persistent organic pollutants, endocrine-</tspan><!--
				--><tspan x="0" y="24">disrupting chemicals, carcinogens, heavy metals</tspan><!--
				--><tspan x="0" y="40"><tspan style="font-weight:bold;">Possible health efects:</tspan> afect cardiovascular, renal, gastro-</tspan><!--
				--><tspan x="0" y="52">intestinal, neurological, reproductive, and respiratory systems; </tspan><!--
				--><tspan x="0" y="64">cancers, diabetes, neuro-, reproductive, and developmental </tspan><!--
				--><tspan x="0" y="76">toxicity</tspan><!--
				--></text>
			</g>
