		</g>
		<g style="fill:#000000;fill-rule: nonzero;stroke:none;">
			<text transform="matrix(0,1,1,0,710,230)"  style="font-size:10px;">© PLASTIC ATLAS 2019 / CIEL</text>
			<text transform="matrix(1,0,0,-1,170,780)" style="font-size:11px;">NO WAY TO AVOID IT</text>
			<text transform="matrix(1,0,0,-1,170,768)" style="font-size:11px;">We are exposed to toxic chemicals and microplastics at all stages in the plastics life cycle.</text>
			<text transform="matrix(1,0,0,-1,170,756)" style="font-size:11px;">The pollutants can get into our bodies in many ways.</text>
			<text transform="matrix(1,0,0,-1,345,733)" style="font-size:12px;font-weight:bold;">Direct contact</text>
			<text transform="matrix(1,0,0,-1,345,393)" style="font-size:12px;font-weight:bold;">Environmental exposure</text>
		</g>
		<g id="legende" transform="translate(400,240)" style="stroke-width:1.5;stroke-linecap:butt;stroke-linejoin:miter;stroke-miterlimit:4;stroke-opacity:1;">
			<g>
				<text transform="matrix(1,0,0,-1,40,43)" style="stroke:none;font-size:10px;text-anchor: middle;">Microplastics</text>
				<text transform="matrix(1,0,0,-1,120,43)" style="stroke:none;font-size:10px;text-anchor: middle;">Chemicals</text>
				<text transform="matrix(1,0,0,-1,0,30)"   style="stroke:none;text-anchor: end;font-size:10px;"><!--
				--><tspan x="0" y="0">Inhalation</tspan><!--
				--><tspan x="0" y="12">Ingestion</tspan><!--
				--><tspan x="0" y="24">Skin contact</tspan></text>
			</g>
