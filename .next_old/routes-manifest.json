{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/gaming/[...path]",
      "regex": "^/api/gaming/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/gaming/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
      "page": "/api/space/[...path]",
      "regex": "^/api/space/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPpath": "nxtPpath"
      },
      "namedRegex": "^/api/space/(?<nxtPpath>.+?)(?:/)?$"
    },
    {
      "page": "/article/[category]/[id]",
      "regex": "^/article/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPcategory": "nxtPcategory",
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/article/(?<nxtPcategory>[^/]+?)/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/category/[slug]",
      "regex": "^/category/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/category/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/hr/article/[category]/[id]",
