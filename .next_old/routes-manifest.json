        "nxtPcategory": "nxtPcategory",
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/hr/article/(?<nxtPcategory>[^/]+?)/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/hr/category/[slug]",
