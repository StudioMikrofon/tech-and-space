0:{"buildId":"IRETGJPjJTJAg2wgYY_7w","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"Metaov NLLB-200 otkriva univerzalnu strukturu jezika – ali što to znači za vas?\",\"description\":\"Kada je Meta [predstavio NLLB-200](https://ai.\",\"image\":\"https://techand.space/images/articles/metas-nllb-200-isnt-just-translatingits-mapping-ho/main.jpg\",\"datePublished\":\"2026-03-11T12:00:00Z\",\"dateModified\":\"2026-03-11T12:00:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"Future Pulse\",\"url\":\"https://futurepulse.hr\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"TECH & SPACE\",\"url\":\"https://techand.space\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://techand.space/logo.jpg\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://techand.space/article/ai/2026-03-11-metas-nllb-200-isnt-just-translatingits-mapping-ho\"},\"inLanguage\":\"hr\",\"articleSection\":\"ai\",\"keywords\":\"future-pulse, automated, ai\"}"}}],["$","$L2",null,{"geo":{"name":"Menlo Park, United States","lat":37.4847,"lon":-122.1481,"countryCode":"US"},"categoryColor":"#6b46c1"}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","children":[["$","div",null,{"className":"flex items-center justify-between mb-6","children":[["$","$L3",null,{"href":"/hr","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Povratak"]}],["$","$L4