0:{"buildId":"IRETGJPjJTJAg2wgYY_7w","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"Robotima 15 minuta pamćenja: MEM sustav daje kontekst za složene zadatke\",\"description\":\"Ako ste ikada pokušali naučiti robota da očisti kuhinju po receptu — ili barem da ne zaboravi što je radio prije dvije minute — znate koliko je to frustrirajuće.\",\"image\":\"https://techand.space/images/articles/robots-get-memory-a-15-minute-leap-for-ai-taskmast/main.jpg\",\"datePublished\":\"2026-03-10T12:00:00Z\",\"dateModified\":\"2026-03-10T12:00:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"Future Pulse\",\"url\":\"https://futurepulse.hr\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"TECH & SPACE\",\"url\":\"https://techand.space\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://techand.space/logo.jpg\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://techand.space/article/ai/2026-03-10-robots-get-memory-a-15-minute-leap-for-ai-taskmast\"},\"inLanguage\":\"hr\",\"articleSection\":\"ai\",\"keywords\":\"future-pulse, automated, ai\"}"}}],["$","$L2",null,{"geo":{"name":"Mountain View, CA","lat":37.3861,"lon":-122.0839,"countryCode":"US"},"categoryColor":"#6b46c1"}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","children":[["$","div",null,{"className":"flex items-center justify-between mb-6","children":[["$","$L3",null,{"href":"/hr","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","path","1l729n",{"