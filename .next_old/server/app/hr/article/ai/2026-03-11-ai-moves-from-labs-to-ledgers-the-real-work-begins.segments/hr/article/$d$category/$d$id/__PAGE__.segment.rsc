en":[["$","span",null,{"className":"category-badge category-badge-ai text-[9px] mb-1 inline-block","children":"AI"}],["$","p",null,{"className":"text-xs text-text-primary group-hover:text-accent-cyan transition-colors leading-tight line-clamp-2","children":"Japan's Agrivoltaic Reality Check: Standards Over Hype"}],["$","div",null,{"className":"flex items-center gap-1 mt-1 text-[10px] text-text-secondary/50","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-2.5 h-2.5","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-03-16T12:00:00Z","children":"Mar 16"}]]}]]}]]}]}],["$","$L3","2026-03-12-rlhfs-blind-spot-can-p-grpo-fix-ais-preference-ech",{"href":"/hr/article/ai/2026-03-12-rlhfs-blind-spot-can-p-grpo-fix-ais-preference-ech","className":"block group","children":["$","div",null,{"className":"flex gap-3 items-start","children":[["$","img",null,{"src":"/images/articles/rlhfs-blind-spot-can-p-grpo-fix-ais-preference-ech/main.jpg","alt":"RLHF’s blind spot: Can P-GRPO fix AI’s preference echo chamber?","className":"w-14 h-14 object-cover rounded flex-shrink-0 opacity-80 group-hover:opacity-100 transition-opacity"}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"category-badge category-badge-ai text-[9px] mb-1 inline-block","children":"AI"}],["$","p",null,{"className":"text-xs text-text-primary group-hover:text-accent-cyan transition-colors leading-tight line-clamp-2","children":"RLHF’s blind spot: Can P-GRPO fix AI’s preference echo chamber?"}],["$","div",null,{"className":"flex items-center gap-1 mt-1 text-[10px] text-text-secondary/50","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"