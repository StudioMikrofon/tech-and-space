93 4 14.993 4 10a8 8 0 0 1 16 0"}],["$","circle","ilqhr7",{"cx":"12","cy":"10","r":"3"}],"$undefined"]}],["$","span",null,{"children":"San Francisco, CA"}]]}],["$","a",null,{"href":"https://arxiv.org/abs/2603.03291","target":"_blank","rel":"noopener noreferrer","className":"flex items-center gap-1 hover:text-accent-cyan transition-colors","children":["$L5","arXiv NLP"]}]]}],"$L6","$undefined","$L7","$L8","$L9"]}],"$La"]}]]}]],["$Lb"],"$Lc"]}],"loading":null,"isPartial":false}
