9:["$","div",null,{"className":"mb-6 not-prose","children":["$","ul",null,{"className":"space-y-2.5 border-l-4 border-yellow-400/50 pl-4","children":[["$","li","0",{"className":"flex items-start gap-2.5 leading-snug","children":[["$","span",null,{"className":"mt-0.5 text-base flex-shrink-0 animate-pulse","style":{"color":"#f5c518","textShadow":"0 0 8px #f5c518, 0 0 18px #f5a500aa"},"children":"★"}],["$","span",null,{"className":"text-xl italic text-text-primary","children":"Genetski 'program' raka otkriven u kolon tumorima"}]]}],["$","li","1",{"className":"flex items-start gap-2.5 leading-snug","children":[["$","span",null,{"className":"mt-0.5 text-base flex-shrink-0 animate-pulse","style":{"color":"#f5c518","textShadow":"0 0 8px #f5c518, 0 0 18px #f5a500aa"},"children":"★"}],["$","span",null,{"className":"text-xl italic text-text-primary","children":"MangroveGS radi na više tipova raka – ali s 20% greške"}]]}],["$","li","2",{"className":"flex items-start gap-2.5 leading-snug","children":[["$","span",null,{"className":"mt-0.5 text-base flex-shrink-0 animate-pulse","style":{"color":"#f5c518","textShadow":"0 0 8px #f5c518, 0 0 18px #f5a500aa"},"children":"★"}],["$","span",null,{"className":"text-xl italic text-text-primary","children":"Liječnici bi mogli manje agresivno liječiti – ako se potvrdi"}]]}]]}]}]
a:["$","div",null,{"className":"article-prose max-w-none","children":[["$","p",null,{"children":["Kada naučnici kažu da je pronađen „biološki program“ metastaza, odmah se čuje zvonjava alarmnih signala: je li ovo još jedan ai koji objašnjava rak kao „složenu, ali predvidivu“ igru, ili stvarno nešto novo? Istraživači s ",["$","a",null,{"href":"https://www.massgeneral.org/","children":"Massachusetts General Hospitala"}]," analizirali su ",["$","strong",null,{"children":"genetske obrasce"}]," u stanicama karcinoma debelog crijeva i utvrdili da metastaze nisu nasumične – barem ne u ovom slučaju. Njegov ai model, ",["$","strong",null,{"children":"MangroveGS"}],", tvrdi da može predvidjeti širenje tumora s ",["$","strong",null,{"children":"~80% točnošću"}],", i to ne samo za debelo crijevo, nego i za druge vrste raka. To zvuči impresivno – dok se ne sjetite da ",["$","strong",null,{"children":"20% neuspjeha"}]," u predviđanju metastaza znači da svaki peti pacijent dobiva ",["$","strong",null,{"children":"pogrešnu procjenu rizika"}],". A to nije mala stvar kada je riječ o odluci između kemoterapije i čekanja. Čak i ako je model ",["$","strong",null,{"children":["$","a",null,{"href":"https://www.nature.com/articles/s41588-023-01650-6","children":["objavljen u ",["$","em",null,{"children":"Nature Genetics"}]]}]}],", pitanje ostaje: ",["$","strong",null,{"children":"koje su stvarne posljedice"}]," kada se ova broja pretvore u kliničku praksu? Za razliku od većine ai modela koji rade s ",["$","strong",null,{"children":"sintetičkim podacima"}]," ili retroaktivnim analizama, ovdje je riječ o ",["$","strong",null,{"children":"realnim tumorskim uzorcima"}],". Ali – kao i uvijek – ",["$","strong",null,{"children":"demo nije produkt"}],". Čak i ako MangroveGS radi bolje od postojećih biomarkera (a to još nije dokazano u širem kliničkom okruženju), ",["$","strong",null,{"children":"tko će biti odgovoran"}]," kada ai pogriješi? Bolnice? Razvijači? Pacijenti?"]}],"\n",["$","div",null,{"className":"not-prose my-8 pt-6 border-t border-white/10","children":[null,["$","div",null,{"className":"glass-card overflow-hidden mb-4 !hover:transform-none","children":["$","img",null,{"src":"/images/articles/mangrovegs-when-80-accuracy-isn-t-enough/subtitle.jpg","alt":"Demo radi na 80%. Pitanje je tko će platiti cijenu pogreške","className":"w-full h-auto max-h-[400px] object-cover"}]}],["$","p",null,{"className":"text-text-secondary italic text-lg leading-relaxed font-medium","children":"Demo radi na 80%. Pitanje je tko će platiti cijenu pogreške"}]]}],"\n",["$","p",null,{"children":["Realni problem nije točnost od 80%, nego ",["$","strong",null,{"children":"što se događa s preostalih 20%"}],". Trenutni standardi, kao ",["$","strong",null,{"children":["$","a",null,{"href":"https://www.oncotypedx.com/","children":"Oncotype DX"}]}]," za rak dojke, imaju slične (ili čak niže) stopu pogreške, ali su ",["$","strong",null,{"children":"odobreni i plaćeni"}]," od osiguranja desetljećima. MangroveGS će morati proći kroz ",["$","strong",null,{"children":"dugoročna klinička ispitivanja"}],", a to znači godine čekanja i milione dolara – prije nego što ikoga zainteresira osim akademske zajednice. Zanimljivije je pitanje ",["$","strong",null,{"children":"tko ovdje stječe prednost"}],". Startupi kao ",["$","strong",null,{"children":["$","a",null,{"href":"https://www.tempus.com/","children":"Tempus"}]}]," ili ",["$","strong",null,{"children":["$","a",null,{"href":"https://www.pathai.com/","children":"PathAI"}]}]," već godinama grade poslovne modele na ai dijagnostici raka, ali im nedostaje upravo ovo: ",["$","strong",null,{"children":"biološki mehanizam"}]," koji objašnjava ",["$","em",null,{"children":"zašto"}]," model radi, a ne samo ",["$","em",null,{"children":"da"}]," radi. Ako se MangroveGS pokaže robustnim, to bi mogao biti ",["$","strong",null,{"children":"prvi korak ka „objašnjivom ai-u“ u onkologiji"}]," – ili još jedna ","$L10"," u nizu. Razvojna zajednica je ","$L11",". Dio kaže da je kod ","$L12"," za široku primjenu, drugi ističu da ","$L13"," za neovisnu validaciju. A to je ključno: dok god nema ","$L14",", sve ostalo je – kao i uvijek – ","$L15",". Pravi signal ovdje nije u točnosti od 80%, nego u činjenici da ","$L16"," imamo ai koji ne samo predviđa, nego ","$L17",". Ako se to potvrdi, liječnici bi mogli ","$L18"," odlučivati o terapiji."]}],"\n","$L19"]}]
