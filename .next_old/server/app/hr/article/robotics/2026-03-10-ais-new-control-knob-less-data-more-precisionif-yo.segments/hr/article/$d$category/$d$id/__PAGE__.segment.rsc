-badge-robotics text-[9px] mb-1 inline-block","children":"Robotics"}],["$","p",null,{"className":"text-xs text-text-primary group-hover:text-accent-cyan transition-colors leading-tight line-clamp-2","children":"Atlas steps out of the lab—into Hyundai’s factory floor"}],["$","div",null,{"className":"flex items-center gap-1 mt-1 text-[10px] text-text-secondary/50","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-2.5 h-2.5","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-03-23T12:00:00Z","children":"Mar 23"}]]}]]}]]}]}],["$","$L3","2026-03-23-demining-drones-show-promise-but-battery-life-is-a",{"href":"/hr/article/robotics/2026-03-23-demining-drones-show-promise-but-battery-life-is-a","className":"block group","children":["$","div",null,{"className":"flex gap-3 items-start","children":[["$","img",null,{"src":"/images/articles/demining-drones-show-promise-but-battery-life-is-a/main.jpg","alt":"Demining drones show promise, but battery life is a battlefield","className":"w-14 h-14 object-cover rounded flex-shrink-0 opacity-80 group-hover:opacity-100 transition-opacity"}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"category-badge category-badge-robotics text-[9px] mb-1 inline-block","children":"Robotics"}],["$","p",null,{"className":"text-xs text-text-primary group-hover:text-accent-cyan transition-colors leading-tight line-clamp-2","children":"Demining drones show promise, but battery life is a battlefield"}],["$","div",null,{"className":"flex items-center gap-1 mt-1 text-[10px] text-text-secondary/50","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-2.5 h-2.5","aria-hidden":"true","children":["$L15","$L16","$undefined"]}],"$L17"]}]]}]]}]}],"$L18","$L19"]}]]}]]}]
