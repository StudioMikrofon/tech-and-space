e:["$","$L1a",null,{"children":["$","$1b",null,{"name":"Next.MetadataOutlet","children":"$@1c"}]}]
f:["$","p",null,{"children":["Da razumijemo zašto je ovo važno, vrijedi pogledati trenutno stanje u industriji. Trenutno, razvoj multimodalnih modela podrazumijeva ",["$","strong",null,{"children":"visoke troškove i veliku potrošnju energije"}],". Prema podacima ",["$","a",null,{"href":"https://www.iea.org/reports/data-centres-and-data-transmission-networks","children":"International Energy Agency"}],", centra podataka već troše oko 1–1.5% globalne električne energije, a AI modeli su jedan od glavnih krivaca za taj rast. Ako Emoryjev okvir stvarno može smanjiti potrebu za podacima i računalnom snagom, to bi moglo biti ",["$","strong",null,{"children":"značajan korak prema „zelenijem“ AI-ju"}]," – barem u teoriji."]}]
10:["$","p",null,{"children":["Međutim, postoji nekoliko prepreka. Prva je ",["$","strong",null,{"children":"adopcija"}],": velike tvrtke poput ",["$","a",null,{"href":"https://openai.com/","children":"OpenAI"}]," ili ",["$","a",null,{"href":"https://www.anthropic.com/","children":"Anthropica"}]," već imaju uspostavljene procese i možda neće htjeti riskirati promjenu. Druga je ",["$","strong",null,{"children":"kompatibilnost"}],": okvir je još uvijek u ranoj fazi, i nije jasno koliko se lako može integrirati u postojeće alate poput ",["$","a",null,{"href":"https://pytorch.org/","children":"PyTorcha"}]," ili ",["$","a",null,{"href":"https://www.tensorflow.org/","children":"TensorFlowa"}],". Treća, i možda najvažnija, je ",["$","strong",null,{"children":"korisničko iskustvo"}],": čak i ako model postane efikasniji, pitanje je hoće li to rezultirati bržim, točnijim ili jeftinijim proizvodima za krajnje korisnike – ili će uštede ostati na razini centra podataka."]}]
11:["$","p",null,{"children":["Zanimljivo je kako ",["$","strong",null,{"children":"robotički sektor"}]," može imati najveću korist od ovog pristupa. Roboti koji rade u stvarnom svijetu (npr. u skladištima ili bolnicama) često moraju procesuirati više vrsta podataka odjednom – slike, zvuk, senzorske podatke – s ograničenim hardverom. Ako ",["$","em",null,{"children":"„control knob“"}]," omogućuje bolju kompresiju bez gubitka ključnih informacija, to bi moglo značiti ",["$","strong",null,{"children":"duže vrijeme rada na bateriji"}]," ili brže odlučivanje u kritičnim situacijama. Međutim, kao što primjećuju neki istraživači iz ",["$","a",null,{"href":"https://www.ri.cmu.edu/","children":"robotike na CMU-u"}],", teorijski modeli često ne uzimaju u obzir ",["$","em",null,{"children":"„šum“"}]," stvarnog svijeta – nepredvidive varijable koje mogu pokvariti čak i najpažljivije dizajnirane algoritme."]}]
12:["$","p",null,{"children":["Na kraju, ovo nije ",["$","em",null,{"children":"„revolucija“"}],", ali je ",["$","strong",null,{"children":"značajan korak prema sistematičnijem razvoju AI-ja"}],". Ako se potvrdi u praksi, mogao bi smanjiti troškove, ubrzati istraživanje i možda čak smanjiti ekološki otisak. Međutim, kao i uvijek, ",["$","strong",null,{"children":"đavo je u detaljima"}]," – a oni će se pokazati tek kada se okvir počne koristiti izvan laboratorija."]}]
