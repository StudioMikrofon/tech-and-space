7:["$","div",null,{"className":"mb-6 not-prose","children":["$","ul",null,{"className":"space-y-2.5 border-l-4 border-yellow-400/50 pl-4","children":[["$","li","0",{"className":"flex items-start gap-2.5 leading-snug","children":[["$","span",null,{"className":"mt-0.5 text-base flex-shrink-0 animate-pulse","style":{"color":"#f5c518","textShadow":"0 0 8px #f5c518, 0 0 18px #f5a500aa"},"children":"★"}],["$","span",null,{"className":"text-xl italic text-text-primary","children":"Pentagon izbjegava kineske komponente — ukrajinski dronovi dobivaju ugovore"}]]}],["$","li","1",{"className":"flex items-start gap-2.5 leading-snug","children":[["$","span",null,{"className":"mt-0.5 text-base flex-shrink-0 animate-pulse","style":{"color":"#f5c518","textShadow":"0 0 8px #f5c518, 0 0 18px #f5a500aa"},"children":"★"}],["$","span",null,{"className":"text-xl italic text-text-primary","children":"Shrike 10 Fiber i F10: što mogu van demonstracije?"}]]}],["$","li","2",{"className":"flex items-start gap-2.5 leading-snug","children":[["$","span",null,{"className":"mt-0.5 text-base flex-shrink-0 animate-pulse","style":{"color":"#f5c518","textShadow":"0 0 8px #f5c518, 0 0 18px #f5a500aa"},"children":"★"}],["$","span",null,{"className":"text-xl italic text-text-primary","children":"Masovna proizvodnja zahtijeva više od „ne-kineske“ etikete"}]]}]]}]}]
8:["$","div",null,{"className":"article-prose max-w-none","children":[["$","p",null,{"children":["Kada Pentagon ",["$","a",null,{"href":"https://www.techradar.com/news/ukrainian-drones-could-replace-dji-in-the-us-as-pentagon-signs-deal-with-mysterious-ukrainian-defense-drones-tech-corporation","children":"potpiše ugovore"}]," vrijedne milijarde dolara s malopoznatom ukrajinskom tvrtkom, a ne s utvrđenim igračima poput ",["$","a",null,{"href":"https://www.dji.com/","children":"DJI-ja"}],", to nije samo pitanje tehnologije — to je geopolitički signal. ",["$","strong",null,{"children":"Ukrajinska Defense Drones Tech Corporation"}]," (UDDTC) iznenadila je struku kada su njena dva modela, ",["$","a",null,{"href":"https://www.armyrecognition.com/defense-news/june-2024/global/ukrainian-shrike-10-fiber-drone-selected-by-us-army-in-billion-dollar-program.html","children":"Shrike 10 Fiber"}]," i F10, prošli izbor u okviru programa ",["$","em",null,{"children":"Drone Dominance"}],", koji eksplicitno traži rješenja ",["$","strong",null,{"children":"bez ikakvih kineskih komponenti"}],"."]}],"\n",["$","p",null,{"children":["Iza marketinške priče o „misterioznom“ ukrajinskom proizvođaču krije se konkretniji zahtjev: Pentagonu treba ",["$","strong",null,{"children":"operativna pouzdanost u realnim uvjetima"}],", a ne samo laboratorijska čista rješenja. Shrike 10 Fiber, na primjer, navodno nudi ",["$","strong",null,{"children":"10-satni let s teretom od 5 kg"}]," i optiku za noćno snimanje — ali takvi podaci često dolaze iz kontroliranih testova. Pravo pitanje glasi: ",["$","strong",null,{"children":"koliko od toga funkcionira u kišnom Afganistanu ili pustinjskom Iraku"}],", gdje prašina, vlaga i elektromagnetski smetnje nisu „edge case“ već svakodnevica?"]}],"\n",["$","p",null,{"children":["Dronovi bez kineskih dijelova nisu nova ideja, ali je njihova ",["$","strong",null,{"children":"masovna primjena"}]," još uvijek upitna. Pentagonov program vrijedan milijardu dolara nije samo o nabavci — to je test ",["$","strong",null,{"children":"skalabilnosti"}],". Ako ukrajinski dronovi ne mogu biti proizvedeni u tisućama komada po prihvatljivoj cijeni ili ako njihovo održavanje zahtijeva specijaliziranu obuku, bit će još jedan primjer ",["$","strong",null,{"children":"tehnologije koja sjaji na papiru, a propada u skladištu"}],"."]}],"\n",["$","div",null,{"className":"not-prose my-8 pt-6 border-t border-white/10","children":[null,["$","div",null,{"className":"glass-card overflow-hidden mb-4 !hover:transform-none","children":["$","img",null,{"src":"/images/articles/ukraines-drones-can-they-outfly-dji-without-chinas/subtitle.jpg","alt":"Od labsa do prakse: Koliko su ukrajinski dronovi spremni za stvarne misije?","className":"w-full h-auto max-h-[400px] object-cover"}]}],["$","p",null,{"className":"text-text-secondary italic text-lg leading-relaxed font-medium","children":"Od labsa do prakse: Koliko su ukrajinski dronovi spremni za stvarne misije?"}]]}],"\n",["$","p",null,{"children":["Prema dostupnim podacima, prednost UDDTC-ovih dronova leži u ",["$","strong",null,{"children":"modularnom dizajnu"}]," koji omogućava brzu zamjenu komponenti — ključno za vojnu upotrebu gdje popravak na terenu mora biti brz i jednostavan. Međutim, ",["$","strong",null,{"children":"baterijski vijek i nosivost"}]," ostaju kritična ograničenja. Shrike 10 Fiber, iako impresivan na papiru, mora dokazati da njegova ",["$","strong",null,{"children":"optika i senzori rade jednako dobro nakon 50 sati leta u prašnjavim uvjetima"}],", a ne samo u prvom demo letu."]}],"\n",["$","p",null,{"children":["Još zanimljivije je pitanje ",["$","strong",null,{"children":"certifikacije i logistike"}],". Američka vojska već ima iskustva s brzim uvodenjem novih tehnologija (npr. ","$Le"," u Ukrajini), ali skaliranje zahtijeva ","$Lf",". Ako ukrajinski dronovi zahtijevaju poseban softver ili dijelove koje treba uvoziti iz Europe, njihova „prednost“ bez kineskih komponenti brzo postaje ","$L10","."]}],"\n","$L11","\n","$L12"]}]
