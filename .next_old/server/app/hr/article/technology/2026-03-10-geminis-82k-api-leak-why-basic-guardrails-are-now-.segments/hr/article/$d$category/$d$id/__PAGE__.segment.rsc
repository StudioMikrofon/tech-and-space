 4 10a8 8 0 0 1 16 0"}],["$","circle","ilqhr7",{"cx":"12","cy":"10","r":"3"}],"$undefined"]}],["$","span",null,{"children":"Mountain View, United States"}]]}],["$","a",null,{"href":"https://futurepulse.hr","target":"_blank","rel":"noopener noreferrer","className":"flex items-center gap-1 hover:text-accent-cyan transition-colors","children":["$L5","Future Pulse"]}]]}],"$L6","$undefined","$L7","$L8","$L9"]}],"$La"]}]]}]],["$Lb"],"$Lc"]}],"loading":null,"isPartial":false}
