th":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-map-pin w-3 h-3","aria-hidden":"true","children":["$L7","$L8","$undefined"]}],"$L9"]}],"$La"]}]]}],"$Lb","$undefined","$Lc","$Ld","$Le","$Lf"]}],"$L10"]}]]}],"$L11"],["$L12"],"$L13"]}],"loading":null,"isPartial":false}
