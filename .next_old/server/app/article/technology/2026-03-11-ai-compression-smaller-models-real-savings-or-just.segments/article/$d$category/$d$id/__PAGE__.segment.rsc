0:{"buildId":"IRETGJPjJTJAg2wgYY_7w","rsc":["$","$1","c",{"children":[[["$","$L2",null,{}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"AI compression: Smaller models, real savings, or just hype?\",\"description\":\"Running a large language model today means wrestling with two hard truths: they’re expensive to operate, and their memory demands are [growing faster than Moore’s Law can keep up](https://arxiv.\",\"image\":\"https://techand.space/images/articles/ai-compression-smaller-models-real-savings-or-just/main.jpg\",\"datePublished\":\"2026-03-11T12:00:00Z\",\"dateModified\":\"2026-03-11T12:00:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"Future Pulse\",\"url\":\"https://futurepulse.hr\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"TECH & SPACE\",\"url\":\"https://techand.space\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://techand.space/logo.jpg\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://techand.space/article/technology/2026-03-11-ai-compression-smaller-models-real-savings-or-just\"},\"articleSection\":\"technology\",\"keywords\":\"future-pulse, automated, technology\"}"}}],["$","$L3",null,{"geo":{"name":"San Sebastián, Spain","lat":43.3209,"lon":-1.9845,"countryCode":"XX"},"categoryColor":"#06b6d4"}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","data-article-db-id":217,"children":[["$","div",null,{"className":"article-enter flex items-center justify-between mb-6","children":[["$","$L4",null,{"href":"/","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide luc