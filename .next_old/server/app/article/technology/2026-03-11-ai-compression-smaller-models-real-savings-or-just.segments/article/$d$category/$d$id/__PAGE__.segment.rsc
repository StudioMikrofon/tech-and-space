ght":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-2.5 h-2.5","aria-hidden":"true","children":["$L19","$L1a","$undefined"]}],"$L1b"]}]]}]]}]}],"$L1c","$L1d"]}]]}]]}]
