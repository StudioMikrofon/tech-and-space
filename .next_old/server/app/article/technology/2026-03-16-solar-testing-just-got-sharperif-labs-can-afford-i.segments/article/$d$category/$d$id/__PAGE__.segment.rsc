0:{"buildId":"IRETGJPjJTJAg2wgYY_7w","rsc":["$","$1","c",{"children":[[["$","$L2",null,{}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"Solar testing just got sharper—if labs can afford it\",\"description\":\"Photovoltaic module testing just crossed into lab-grade precision territory—but the real question isn’t whether the tech works, but who can actually use it.\",\"image\":\"https://techand.space/images/articles/solar-testing-just-got-sharperif-labs-can-afford-i/main.jpg\",\"datePublished\":\"2026-03-16T12:00:00Z\",\"dateModified\":\"2026-03-16T12:00:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"\",\"url\":\"\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"TECH & SPACE\",\"url\":\"https://techand.space\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://techand.space/logo.jpg\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://techand.space/article/technology/2026-03-16-solar-testing-just-got-sharperif-labs-can-afford-i\"},\"articleSection\":\"technology\",\"keywords\":\"Solar Simulator, Certification Costs, Renewable Energy\"}"}}],["$","$L3",null,{"geo":{"name":"Madrid, Spain","lat":40.416775,"lon":-3.70379,"countryCode":"XX"},"categoryColor":"#06b6d4"}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","data-article-db-id":424,"children":[["$","div",null,{"className":"article-enter flex items-center justify-between mb-6","children":[["$","$L4",null,{"href":"/","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","p