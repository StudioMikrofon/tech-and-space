3:T4e8,{"@context":"https://schema.org","@type":"NewsArticle","headline":"Intel’s Heracles chip crushes encryption’s biggest bottleneck","description":"Fully homomorphic encryption (FHE) has been the ‘holy grail’ of data security for over a decade: the ability to compute on encrypted data without ever decrypting it, eliminating entire classes of attacks from cloud leaks to side-channel exploits.","image":"https://techand.space/images/articles/intels-heracles-chip-crushes-encryptions-biggest-b/main.jpg","datePublished":"2026-03-11T12:00:00Z","dateModified":"2026-03-11T12:00:00Z","author":{"@type":"Organization","name":"Tom's Hardware","url":"https://www.tomshardware.com/tech-industry/cyber-security/intels-heracles-chip-computes-fully-encrypted-data-without-decrypting-it-chip-is-1-074-to-5-547-times-faster-than-a-24-core-intel-xeon-in-fhe-math-operations"},"publisher":{"@type":"Organization","name":"TECH & SPACE","url":"https://techand.space","logo":{"@type":"ImageObject","url":"https://techand.space/logo.jpg"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://techand.space/article/technology/2026-03-11-intels-heracles-chip-crushes-encryptions-biggest-b"},"articleSection":"technology","keywords":"future-pulse, automated, technology"}0:{"buildId":"IRETGJPjJTJAg2wgYY_7w","rsc":["$","$1","c",{"children":[[["$","$L2",null,{}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$3"}}],["$","$L4",null,{"geo":{"name":"Santa Clara, United States","lat":37.3541,"lon":-121.9552,"countryCode":"US"},"categoryColor":"#06b6d4"}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","data-article-db-id":244,"children":[["$","div",null,{"className":"article-enter flex items-center justify-between mb-6","children":[["$","$L5",null,{"href":"/","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org