0:{"buildId":"IRETGJPjJTJAg2wgYY_7w","rsc":["$","$1","c",{"children":[[["$","$L2",null,{}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"385 TB Saved: Gaming's Biggest Archive Lives On\",\"description\":\"When Myrient announced its March 31st closure, the gaming preservation world held its breath.\",\"image\":\"https://techand.space/images/articles/385-tb-saved-gaming-s-biggest-archive-lives-on/main.jpg\",\"datePublished\":\"2026-03-16T12:00:00Z\",\"dateModified\":\"2026-03-16T12:00:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"\",\"url\":\"\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"TECH & SPACE\",\"url\":\"https://techand.space\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://techand.space/logo.jpg\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://techand.space/article/gaming/2026-03-16-385-tb-saved-gaming-s-biggest-archive-lives-on\"},\"articleSection\":\"gaming\",\"keywords\":\"Internet Archive, Game Preservation, Community Driven\"}"}}],["$","$L3",null,{"geo":{"name":"Global","lat":0,"lon":0,"countryCode":"XX"},"categoryColor":"#eab308"}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","data-article-db-id":401,"children":[["$","div",null,{"className":"article-enter flex items-center justify-between mb-6","children":[["$","$L4",null,{"href":"/","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Back to Home"]}],["$","$L5",null,{"lang":"en","href":"/hr/article/gaming/2026-03-16-385-tb-saved-gaming-s-biggest-archive-lives-on"}]]}],["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8","children":[["$","div",null,{"children":[["$","div",null,{"className":"article-enter-delay-1","children":[["$","div",null,{"className":"flex items-center gap-2 flex-wrap mb-4","children":[["$","$L4",null,{"href":"/category/gaming","className":"category-badge category-badge-gaming cursor-pointer hover:opacity-80 transition-opacity","children":"Gaming"}],[["$","span",null,{"className":"text-[10px] font-mono border rounded px-1.5 py-0.5 text-accent-cyan/60 border-accent-cyan/20","children":"db#401"}],["$","$L6",null,{"articleId":401}]]]}],["$","h1",null,{"className":"font-heading text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary leading-tight mb-4","children":"385 TB Saved: Gaming's Biggest Archive Lives On"}],["$","div",null,{"className":"flex flex-wrap items-center gap-4 mb-6 text-sm text-text-secondary","children":[["$","div",null,{"className":"flex items-center gap-1","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-4 h-4","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-03-16T12:00:00Z","children":["March 16, 2026",["$","span",null,{"className":"ml-1 opacity-50","children":"12:00"}]]}],["$","span",null,{"className":"ml-1 opacity-60","children":["(","1w ago",")"]}]]}],["$","div",null,{"className":"flex items-center gap-1 text-accent-cyan/70","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-map-pin w-3 h-3","aria-hidden":"true","children":[["$","path","1r0f0z",{"d":"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"}],"$L7","$undefined"]}],"$L8"]}],""]}]]}],"$L9","$undefined","$La","$Lb","$Lc","$Ld"]}],"$Le"]}]]}],"$Lf"],["$L10"],"$L11"]}],"loading":null,"isPartial":false}
