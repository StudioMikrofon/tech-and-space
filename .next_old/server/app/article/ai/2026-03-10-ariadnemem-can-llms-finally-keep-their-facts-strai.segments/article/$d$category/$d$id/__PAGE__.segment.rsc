trokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-map-pin w-3 h-3","aria-hidden":"true","children":[["$","path","1r0f0z",{"d":"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"}],"$L7","$undefined"]}],"$L8"]}],"$L9"]}]]}],"$La","$undefined","$Lb","$Lc","$Ld","$Le"]}],"$Lf"]}]]}],"$L10"],["$L11"],"$L12"]}],"loading":null,"isPartial":false}
