100 transition-opacity"}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"category-badge category-badge-ai text-[9px] mb-1 inline-block","children":"AI"}],"$L16","$L17"]}]]}]}],"$L18"]}]]}]]}]
