:"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-2.5 h-2.5","aria-hidden":"true","children":["$L17","$L18","$undefined"]}],"$L19"]}]]}]]}]}],"$L1a","$L1b"]}]]}]]}]
