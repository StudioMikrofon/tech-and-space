0:{"buildId":"8BczN53qI8xXbjPXJW-p6","rsc":["$","$1","c",{"children":[[["$","$L2",null,{}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"GPT-5.3 Instant: The AI that finally stops gaslighting its users\",\"description\":\"For months, ChatGPT users have endured an AI that acted less like a tool and more like a condescending intern—lecturing them to [*‘stay calm’*](https://www.\",\"image\":\"https://techand.space/images/articles/gpt-5-3-instant-the-ai-that-finally-stops-gaslight/main.jpg\",\"datePublished\":\"2026-03-11T12:00:00Z\",\"dateModified\":\"2026-03-11T12:00:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"Future Pulse\",\"url\":\"https://futurepulse.hr\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"TECH & SPACE\",\"url\":\"https://techand.space\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://techand.space/logo.jpg\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://techand.space/article/ai/2026-03-11-gpt-5-3-instant-the-ai-that-finally-stops-gaslight\"},\"articleSection\":\"ai\",\"keywords\":\"future-pulse, automated, ai\"}"}}],["$","$L3",null,{"geo":{"name":"San Francisco, United States","lat":37.7749,"lon":-122.4194,"countryCode":"US"},"categoryColor":"#6b46c1"}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","data-article-db-id":218,"children":[["$","div",null,{"className":"article-enter flex items-center justify-between mb-6","children":[["$","$L4",null,{"href":"/","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","c