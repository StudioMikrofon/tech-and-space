,null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-map-pin w-3 h-3","aria-hidden":"true","children":["$L7","$L8","$undefined"]}],"$L9"]}],""]}]]}],"$La","$undefined","$Lb","$Lc","$Ld","$Le"]}],"$Lf"]}]]}],"$L10"],["$L11"],"$L12"]}],"loading":null,"isPartial":false}
