0:{"buildId":"8BczN53qI8xXbjPXJW-p6","rsc":["$","$1","c",{"children":[[["$","$L2",null,{}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"Foldable iPhone’s 12GB RAM: Samsung’s Price Power Play\",\"description\":\"The foldable iPhone’s arrival was always going to be a spectacle, but its 12GB RAM—supplied exclusively by Samsung—is the first concrete sign that Apple’s supply chain is bending under pressure.\",\"image\":\"https://techand.space/images/articles/foldable-iphones-12gb-ram-samsungs-price-power-pla/main.jpg\",\"datePublished\":\"2026-03-16T12:00:00Z\",\"dateModified\":\"2026-03-16T12:00:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"\",\"url\":\"\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"TECH & SPACE\",\"url\":\"https://techand.space\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://techand.space/logo.jpg\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://techand.space/article/technology/2026-03-16-foldable-iphones-12gb-ram-samsungs-price-power-pla\"},\"articleSection\":\"technology\",\"keywords\":\"Samsung, iPhone, Apple, Foldable Smartphone, Memory Pricing\"}"}}],["$","$L3",null,{"geo":{"name":"Global","lat":0,"lon":0,"countryCode":"XX"},"categoryColor":"#06b6d4"}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","data-article-db-id":412,"children":[["$","div",null,{"className":"article-enter flex items-center justify-between mb-6","children":[["$","$L4",null,{"href":"/","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"tr