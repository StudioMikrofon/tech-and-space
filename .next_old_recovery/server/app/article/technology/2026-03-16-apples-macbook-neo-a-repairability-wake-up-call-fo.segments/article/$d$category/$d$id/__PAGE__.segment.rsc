0:{"buildId":"8BczN53qI8xXbjPXJW-p6","rsc":["$","$1","c",{"children":[[["$","$L2",null,{}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"Apple’s MacBook Neo: A repairability wake-up call for the industry\",\"description\":\"For years, Apple’s laptops have been the poster children for disposable tech: glued-shut unibody designs, proprietary screws, and batteries that required a PhD in adhesive chemistry to replace.\",\"image\":\"https://techand.space/images/articles/apples-macbook-neo-a-repairability-wake-up-call-fo/main.jpg\",\"datePublished\":\"2026-03-16T12:00:00Z\",\"dateModified\":\"2026-03-16T12:00:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"\",\"url\":\"\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"TECH & SPACE\",\"url\":\"https://techand.space\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://techand.space/logo.jpg\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://techand.space/article/technology/2026-03-16-apples-macbook-neo-a-repairability-wake-up-call-fo\"},\"articleSection\":\"technology\",\"keywords\":\"MacBook Neo, Right to Repair, Modular Design, Sustainability\"}"}}],["$","$L3",null,{"geo":{"name":"Cupertino, United States","lat":37.323,"lon":-122.0322,"countryCode":"US"},"categoryColor":"#06b6d4"}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","data-article-db-id":413,"children":[["$","div",null,{"className":"article-enter flex items-center justify-between mb-6","children":[["$","$L4",null,{"href":"/","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide l