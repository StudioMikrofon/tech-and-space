ry-badge category-badge-technology text-[9px] mb-1 inline-block","children":"Technology"}],["$","p",null,{"className":"text-xs text-text-primary group-hover:text-accent-cyan transition-colors leading-tight line-clamp-2","children":"A Billion Windows PCs Face Security Certificate Crisis"}],["$","div",null,{"className":"flex items-center gap-1 mt-1 text-[10px] text-text-secondary/50","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-2.5 h-2.5","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-03-16T12:00:00Z","children":"Mar 16"}]]}]]}]]}]}],["$","$L4","2026-03-16-swift-solar-buys-meyer-burger-tech-to-anchor-us-hj",{"href":"/article/technology/2026-03-16-swift-solar-buys-meyer-burger-tech-to-anchor-us-hj","className":"block group","children":["$","div",null,{"className":"flex gap-3 items-start","children":[["$","img",null,{"src":"/images/articles/swift-solar-buys-meyer-burger-tech-to-anchor-us-hj/main.jpg","alt":"Swift Solar Buys Meyer Burger Tech to Anchor US HJT Production","className":"w-14 h-14 object-cover rounded flex-shrink-0 opacity-80 group-hover:opacity-100 transition-opacity"}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"category-badge category-badge-technology text-[9px] mb-1 inline-block","children":"Technology"}],["$","p",null,{"className":"text-xs text-text-primary group-hover:text-accent-cyan transition-colors leading-tight line-clamp-2","children":"Swift Solar Buys Meyer Burger Tech to Anchor US HJT Production"}],["$","div",null,{"className":"flex items-center gap-1 mt-1 text-[10px] text-text-secondary/50","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-2.5 h-2.5","aria-hidden":"true","children":["$L18","$L19","$undefined"]}],"$L1a"]}]]}]]}]}],"$L1b","$L1c"]}]]}]]}]
