0:{"buildId":"8BczN53qI8xXbjPXJW-p6","rsc":["$","$1","c",{"children":[[["$","$L2",null,{}],["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"AI’s new ‘control knob’: Less data, more precision—if you know how to use it\",\"description\":\"For years, building multimodal AI—systems that juggle text, images, audio, and more—has been a high-stakes guessing game.\",\"image\":\"https://techand.space/images/articles/ais-new-control-knob-less-data-more-precisionif-yo/main.jpg\",\"datePublished\":\"2026-03-10T12:00:00Z\",\"dateModified\":\"2026-03-10T12:00:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"Future Pulse\",\"url\":\"https://futurepulse.hr\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"TECH & SPACE\",\"url\":\"https://techand.space\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://techand.space/logo.jpg\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://techand.space/article/robotics/2026-03-10-ais-new-control-knob-less-data-more-precisionif-yo\"},\"articleSection\":\"robotics\",\"keywords\":\"future-pulse, automated, robotics\"}"}}],["$","$L3",null,{"geo":{"name":"Atlanta, United States","lat":33.749,"lon":-84.388,"countryCode":"US"},"categoryColor":"#10b981"}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","data-article-db-id":206,"children":[["$","div",null,{"className":"article-enter flex items-center justify-between mb-6","children":[["$","$L4",null,{"href":"/","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$"