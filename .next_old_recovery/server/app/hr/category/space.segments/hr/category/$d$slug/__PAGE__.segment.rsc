","Satellite Constellation","Low Earth Orbit","Data Center"],"geo":{"name":"Redmond, WA","lat":47.6739,"lon":-122.1214,"countryCode":"US"},"featured":false,"approved":true,"content":"$23","lang":"hr"},{"id":"2026-03-16-the-xbox-one-jailbreak-a-victory-for-digital-prese","title":"Jailbreak Xbox Onea: Zašto je ovo važno za očuvanje tehnologije","category":"space","date":"2026-03-16T12:00:00Z","scrapeDateDate":"2026-03-16T12:00:00Z","excerpt":"Kada se 2013.","source":{"name":"","url":""},"image":{"url":"/images/articles/the-xbox-one-jailbreak-a-victory-for-digital-prese/main.jpg","alt":"Jailbreak Xbox Onea: Zašto je ovo važno za očuvanje tehnologije"},"subtitle":"Kontekst u dvije rečenice: od igračke konzole do laboratorija za istraživanje trajnosti elektronike","subtitleImage":{"url":"/images/articles/the-xbox-one-jailbreak-a-victory-for-digital-prese/subtitle.jpg","alt":"Kontekst u dvije rečenice: od igračke konzole do laboratorija za istraživanje trajnosti elektronike"},"tags":["future-pulse","automated","space"],"geo":{"name":"Redmond, United States","lat":47.678,"lon":-122.1303,"countryCode":"US"},"featured":false,"approved":true,"content":"$24","lang":"hr"},{"id":"2026-03-12-a-cosmic-collision-reveals-how-gold-and-platinum-a","title":"Sudar neutronskih zvijezda otkriva tajne teških elemenata","category":"space","date":"2026-03-12T12:00:00Z","scrapeDateDate":"2026-03-12T12:00:00Z","excerpt":"Sudar neutronskih zvijezda otkriva tajne teških elemenata","source":{"name":"Future Pulse","url":"https://futurepulse.hr"},"image":{"url":"/images/articles/a-cosmic-collision-reveals-how-gold-and-platinum-a/main.jpg","alt":"Sudar neutronskih zvijezda otkriva tajne teških elemenata"},"subtitle":"Kako 15-sekundni gama-bljesak mijenja naše razumijevanje nastanka metala","subtitleImage":{"url":"/images/articles/a-cosmic-collision-reveals-how-gold-and-platinum-a/subtitle.jpg","alt":"Kako 15-sekundni gama-bljesak mijenja naše razumijevanje nastanka metala"},"tags":["future-pulse","a