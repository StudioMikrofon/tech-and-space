0:{"buildId":"8BczN53qI8xXbjPXJW-p6","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"Gatesov reaktor dobio zeleno svjetlo – što to znači za energiju?\",\"description\":\"Nuklearna energija se vraća na scenu, ali ovaj put s etiketom *napredno* i potpisom jednog od najutjecajnijih tech milijardera.\",\"image\":\"https://techand.space/images/articles/bill-gates-nuclear-reactor-gets-approvalwhat-it-ac/main.jpg\",\"datePublished\":\"2026-03-10T12:00:00Z\",\"dateModified\":\"2026-03-10T12:00:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"Future Pulse\",\"url\":\"https://futurepulse.hr\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"TECH & SPACE\",\"url\":\"https://techand.space\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://techand.space/logo.jpg\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://techand.space/article/technology/2026-03-10-bill-gates-nuclear-reactor-gets-approvalwhat-it-ac\"},\"inLanguage\":\"hr\",\"articleSection\":\"technology\",\"keywords\":\"future-pulse, automated, technology\"}"}}],["$","$L2",null,{"geo":{"name":"Wyoming, United States","lat":43.07597,"lon":-107.29028,"countryCode":"US"},"categoryColor":"#06b6d4"}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","children":[["$","div",null,{"className":"flex items-center justify-between mb-6","children":[["$","$L3",null,{"href":"/hr","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","path","1l729n",{"d":"m12 19-