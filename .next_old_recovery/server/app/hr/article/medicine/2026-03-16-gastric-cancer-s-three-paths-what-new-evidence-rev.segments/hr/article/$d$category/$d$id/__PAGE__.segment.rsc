 mb-1 inline-block","children":"Medicine"}],["$","p",null,{"className":"text-xs text-text-primary group-hover:text-accent-cyan transition-colors leading-tight line-clamp-2","children":"CO₂ Is Rising in Our Blood. Scientists Aren't Sure What It Means."}],["$","div",null,{"className":"flex items-center gap-1 mt-1 text-[10px] text-text-secondary/50","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-2.5 h-2.5","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-03-16T12:00:00Z","children":"Mar 16"}]]}]]}]]}]}],["$","$L3","2026-03-16-smart-underwear-study-suggests-higher-daily-gas-co",{"href":"/hr/article/medicine/2026-03-16-smart-underwear-study-suggests-higher-daily-gas-co","className":"block group","children":["$","div",null,{"className":"flex gap-3 items-start","children":[["$","img",null,{"src":"/images/articles/smart-underwear-study-suggests-higher-daily-gas-co/main.jpg","alt":"Smart Underwear Study Suggests Higher Daily Gas Counts","className":"w-14 h-14 object-cover rounded flex-shrink-0 opacity-80 group-hover:opacity-100 transition-opacity"}],["$","div",null,{"className":"min-w-0","children":[["$","span",null,{"className":"category-badge category-badge-medicine text-[9px] mb-1 inline-block","children":"Medicine"}],["$","p",null,{"className":"text-xs text-text-primary group-hover:text-accent-cyan transition-colors leading-tight line-clamp-2","children":"Smart Underwear Study Suggests Higher Daily Gas Counts"}],["$","div",null,{"className":"flex items-center gap-1 mt-1 text-[10px] text-text-secondary/50","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-2.5 h-2.5","aria-hidden":"true","children":["$L14","$L15","$undefined"]}],"$L16"]}]]}]]}]}],"$L17","$L18"]}]]}]]}]
