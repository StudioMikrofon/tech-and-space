5:["$","a",null,{"href":"","target":"_blank","rel":"noopener noreferrer","className":"flex items-center gap-1 hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-external-link w-3 h-3","aria-hidden":"true","children":[["$","path","1q9fwt",{"d":"M15 3h6v6"}],["$","path","gplh6r",{"d":"M10 14 21 3"}],["$","path","a6xqqp",{"d":"M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"}],"$undefined"]}],""]}]
6:["$","div",null,{"className":"glass-card overflow-hidden mb-8 !hover:transform-none","children":["$","img",null,{"src":"/images/articles/gastric-cancer-s-three-paths-what-new-evidence-rev/main.jpg","alt":"Tri nova puta do raka želuca – što studija zaista otkriva?","className":"w-full h-auto max-h-[400px] object-cover"}]}]
7:["$","div",null,{"className":"article-prose max-w-none","children":[["$","p",null,{"children":["Rak želuca ostaje jedan od najsmrtonosnijih oblika malignih bolesti, s ",["$","a",null,{"href":"https://gco.iarc.fr/today/data/factsheets/cancers/16-Stomach-fact-sheet.pdf","children":"više od milijun novih slučajeva godišnje"}]," širom svijeta. Dok je ",["$","em",null,{"children":"Helicobacter pylori"}]," dugo bio glavni optuženi za njegov razvoj, nova studija objavljena u uglednom časopisu ",["$","a",null,{"href":"https://gut.bmj.com/","children":["$","em",null,{"children":"Gut"}]}]," sugerira da je priča daleko kompleksnija. Istraživači su identificirali ",["$","strong",null,{"children":"tri različita biološka puta"}]," koji vode do raka želuca – svaki s vlastitim obilježjima, prognozom i potencijalnim terapijskim meta."]}],"\n",["$","p",null,{"children":["Ključno otkriće nije samo u broju puteva, već u njihovoj povezanosti s ",["$","strong",null,{"children":"interakcijama između okoline, mikroba, domaćina i biologije tumora"}],". To znači da rak želuca nije jedinstvena bolest, već skup različitih stanja koja zahtijevaju različite pristupe. Na primjer, jedan od identificiranih puteva povezan je s ",["$","strong",null,{"children":"imunološkim odgovorom i upalom"}],", dok drugi pokazuje vezu s ",["$","strong",null,{"children":"metabolizmom i staničnim stresom"}],". Treći put, pak, sugerira ulogu ",["$","strong",null,{"children":"epigenetičkih promjena"}]," – modificiranja gena bez izmjene njihove DNK sekvence."]}],"\n",["$","p",null,{"children":["Međutim, važno je naglasiti: radi se o ",["$","strong",null,{"children":"observacijskoj studiji"}],", a ne o kliničkom ispitivanju novih terapija. Autori su analizirali uzorke tkiva i podatke od ",["$","strong",null,{"children":"nekoliko stotina pacijenata"}],", ali rezultati još uvijek moraju biti potvrđeni u većim, prospektivnim istraživanjima. Što to znači za pacijente danas? ",["$","strong",null,{"children":"Ništa ne mijenja u standardnom liječenju"}]," – barem ne odmah. Ali otvara vrata za razumijevanje zašto neki pacijenti bolje odgovaraju na određene terapije, dok drugi ne."]}],"\n",["$","p",null,{"children":["Jedno od najzanimljivijih pitanja koje studija postavlja jest ",["$","strong",null,{"children":["moguća ulogu mikrobima izvan ",["$","em",null,{"children":"H. pylori"}]]}],". Dok je ova bakterija dugogodišnji glavni sumnjivac, novi nalazi ukazuju da drugi mikrobi – ili čak cjelokupna mikrobiota želuca – mogu igrati ulogu u razvoju bolesti. To bi moglo objasniti zašto neki ljudi razbolijevaju iako nisu zaraženi ",["$","em",null,{"children":"H. pylori"}],", ili zašto neki zaraženi nikad ne razviju rak."]}],"\n",["$","div",null,{"className":"not-prose my-8 pt-6 border-t border-white/10","children":[null,["$","div",null,{"className":"glass-card overflow-hidden mb-4 !hover:transform-none","children":["$","img",null,{"src":"/images/articles/gastric-cancer-s-three-paths-what-new-evidence-rev/subtitle.jpg","alt":"Što studija stvarno pokazuje – i što još uvijek ne znamo","className":"w-full h-auto max-h-[400px] object-cover"}]}],["$","p",null,{"className":"text-text-secondary italic text-lg leading-relaxed font-medium","children":"Što studija stvarno pokazuje – i što još uvijek ne znamo"}]]}],"\n",["$","p",null,{"children":["Da bi razumjeli značaj ove studije, moramo razlikovati ",["$","strong",null,{"children":"što znamo"}]," od ",["$","strong",null,{"children":"čega samo nagađamo"}],". ",["$","strong",null,{"children":"Potvrđeno"}]," je da postoje barem tri različita biološka puta raka želuca, svaki s različitim molekularnim obilježjima. ",["$","strong",null,{"children":"Potvrđeno"}]," je i da ti putevi imaju različite prognoze – što bi eventualno moglo pomoći liječnicima da preciznije predviđaju tijek bolesti. Međutim, ","$Ld"," da bilo koja od ovih spoznaja može već danas promijeniti način liječenja."]}],"\n","$Le","\n","$Lf","\n","$L10","\n","$L11"]}]
