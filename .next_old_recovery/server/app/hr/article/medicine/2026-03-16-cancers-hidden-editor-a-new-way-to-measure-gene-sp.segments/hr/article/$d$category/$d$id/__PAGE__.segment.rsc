,"cy":"10","r":"3"}],"$undefined"]}],["$","span",null,{"children":"Menlo Park, CA"}]]}],["$","a",null,{"href":"","target":"_blank","rel":"noopener noreferrer","className":"flex items-center gap-1 hover:text-accent-cyan transition-colors","children":["$L5",""]}]]}],"$L6","$undefined","$L7","$L8","$L9"]}],"$La"]}]]}]],["$Lb"],"$Lc"]}],"loading":null,"isPartial":false}
