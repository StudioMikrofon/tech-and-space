7:["$","div",null,{"className":"mb-6 not-prose","children":["$","ul",null,{"className":"space-y-2.5 border-l-4 border-yellow-400/50 pl-4","children":[["$","li","0",{"className":"flex items-start gap-2.5 leading-snug","children":[["$","span",null,{"className":"mt-0.5 text-base flex-shrink-0 animate-pulse","style":{"color":"#f5c518","textShadow":"0 0 8px #f5c518, 0 0 18px #f5a500aa"},"children":"★"}],["$","span",null,{"className":"text-xl italic text-text-primary","children":"Jasne veze između prehrane i crijevnih bakterija"}]]}],["$","li","1",{"className":"flex items-start gap-2.5 leading-snug","children":[["$","span",null,{"className":"mt-0.5 text-base flex-shrink-0 animate-pulse","style":{"color":"#f5c518","textShadow":"0 0 8px #f5c518, 0 0 18px #f5a500aa"},"children":"★"}],["$","span",null,{"className":"text-xl italic text-text-primary","children":"Podaci s 10.068 sudionika – ali još uvijek istraživački stadij"}]]}],["$","li","2",{"className":"flex items-start gap-2.5 leading-snug","children":[["$","span",null,{"className":"mt-0.5 text-base flex-shrink-0 animate-pulse","style":{"color":"#f5c518","textShadow":"0 0 8px #f5c518, 0 0 18px #f5a500aa"},"children":"★"}],["$","span",null,{"className":"text-xl italic text-text-primary","children":"Moguća prilagođena prehrana za bolje srčano zdravlje"}]]}]]}]}]
8:["$","div",null,{"className":"article-prose max-w-none","children":[["$","p",null,{"children":["Kada je riječ o prehrani, sve je individualno. Ili barem tako sugeriraju rezultati nove studije objavljene u ",["$","em",null,{"children":"Nature Medicine"}],", koja je analizirala podatke o ",["$","strong",null,{"children":"10.068 sudionika"}]," iz ",["$","a",null,{"href":"https://www.nature.com/articles/s41591-026-04312-x","children":"Human Phenotype Projecta"}],". Naučnici su identificirali ",["$","strong",null,{"children":"uporne obrasce"}]," kako određena hrana utječe na sastav crijevnog mikrobioma – a ti obrasci, čini se, mogu poslužiti kao osnov za ",["$","strong",null,{"children":"prilagođenu prehranu"}]," koja bi poboljšala kardiometaboličko zdravlje. Ovo nije prva studija koja povezuje prehranu i mikrobiom, ali je jedna od najvećih po obimu. Međutim, važno je istaknuti: radi se o ",["$","strong",null,{"children":"observacijskoj studiji"}]," (razina dokaza: istraživački stadij), što znači da pokazuje ",["$","strong",null,{"children":"korelacije"}],", a ne uzročno-posljedične veze. Drugim riječima, ne možemo još reći da određena prehrana ",["$","em",null,{"children":"uzrokuje"}]," promjene u mikrobiomu koje zatim vode boljem zdravlju – već samo da postoje ",["$","strong",null,{"children":"jasni obrasci"}]," koji zahtijevaju daljnje istraživanje. Što studija ",["$","em",null,{"children":"ne"}]," dokazuje? Da već danas možemo propisivati personalizirane prehrambene planove na temelju mikrobioma. Za to bi bile potrebne ",["$","strong",null,{"children":"kliničke studije"}]," (RCT) koje će testirati konkretne intervencije, a one još uvijek ",["$","strong",null,{"children":"nisu ni započete"}],"."]}],"\n",["$","div",null,{"className":"not-prose my-8 pt-6 border-t border-white/10","children":[null,["$","div",null,{"className":"glass-card overflow-hidden mb-4 !hover:transform-none","children":["$","img",null,{"src":"/images/articles/gut-bacteria-and-diet-a-10-000-person-study-with-l/subtitle.jpg","alt":"Velika studija pokazuje trajne obrasce – ali ključna pitanja ostaju","className":"w-full h-auto max-h-[400px] object-cover"}]}],["$","p",null,{"className":"text-text-secondary italic text-lg leading-relaxed font-medium","children":"Velika studija pokazuje trajne obrasce – ali ključna pitanja ostaju"}]]}],"\n",["$","p",null,{"children":["Metodologija studije zasniva se na ",["$","strong",null,{"children":"velikom uzorku"}],", ali ima i ograničenja. Sudionici su uglavnom iz zapadnih zemalja, što znači da rezultati možda nisu univerzalno primjenjivi. Osim toga, mikrobiom je dinamičan – utječu na njega ne samo prehrana, nego i ",["$","strong",null,{"children":"genetika, životna dob, lijekovi"}]," pa čak i stres. Studija je to uzela u obzir, ali takvi faktori ipak kompliciraju interpretaciju. Za pacijente ovo znači sljedeće: ako se ovi nalazi potvrde u budućim istraživanjima, mogli bismo dobiti ",["$","strong",null,{"children":"preciznije prehrambene smjernice"}]," za sprječavanje bolesti poput dijabetesa ili srca. No, za sada ostaje ",["$","strong",null,{"children":"istovjetno kao i prije"}],": opće prehrambene preporuke (više vlakana, manje ultraprerađene hrane) još uvijek vrijede. ",["$","a",null,{"href":"https://www.who.int/","children":"Světska zdravstvena organizacija"}]," i dalje naglašava da ",["$","strong",null,{"children":"nema 'čudesne' prehrane"}]," – a ovo istraživanje to ne opovrgava, već samo dodaje novi sloj razumijevanja. Zanimljivo je da su autori koristili ",["$","strong",null,{"children":"računalne simulacije"}]," kako bi predvidjeli kako bi određene promjene u prehrani mogle utjecati na mikrobiom. To je koristan alat za buduća istraživanja, ali ","$Le"," na ljudima."]}],"\n","$Lf"]}]
