:"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-2.5 h-2.5","aria-hidden":"true","children":["$L11","$L12","$undefined"]}],"$L13"]}]]}]]}]}],"$L14","$L15"]}]]}]]}]
