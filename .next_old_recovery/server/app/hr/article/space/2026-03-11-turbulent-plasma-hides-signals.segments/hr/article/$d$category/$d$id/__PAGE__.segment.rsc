0:{"buildId":"8BczN53qI8xXbjPXJW-p6","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"NewsArticle\",\"headline\":\"Plazma zvijezda može prikriti vanzemaljske signale\",\"description\":\"Ako pretpostavimo da u svemiru postoje tehnološke civilizacije koje pokušavaju komunicirati, njihovi signali možda nikad neće stići do naših teleskopa – ne zato što su preslabi, nego zato što ih *priroda sama sabotaže*.\",\"image\":\"https://techand.space/images/articles/turbulent-plasma-hides-signals/main.jpg\",\"datePublished\":\"2026-03-11T12:00:00Z\",\"dateModified\":\"2026-03-11T12:00:00Z\",\"author\":{\"@type\":\"Organization\",\"name\":\"Future Pulse\",\"url\":\"https://futurepulse.hr\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"TECH & SPACE\",\"url\":\"https://techand.space\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://techand.space/logo.jpg\"}},\"mainEntityOfPage\":{\"@type\":\"WebPage\",\"@id\":\"https://techand.space/article/space/2026-03-11-turbulent-plasma-hides-signals\"},\"inLanguage\":\"hr\",\"articleSection\":\"space\",\"keywords\":\"future-pulse, automated, space\"}"}}],["$","$L2",null,{}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","children":[["$","div",null,{"className":"flex items-center justify-between mb-6","children":[["$","$L3",null,{"href":"/hr","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Povratak"]}],["$","$L4",null,{"lang":"hr","href":"/article/space/2026-03-11-turbulent-plasma-hides-signals"}]]}],["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8","children":[["$","div",null,{"children":[["$","div",null,{"className":"flex items-center gap-2 flex-wrap mb-4","children":[["$","span",null,{"className":"category-badge category-badge-space","children":"Space"}],[["$","span",null,{"className":"text-[10px] font-mono border rounded px-1.5 py-0.5 text-red-400/50 border-red-400/20","children":"no db_id"}],"$undefined"]]}],["$","h1",null,{"className":"font-heading text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-text-primary leading-tight mb-4","children":"Plazma zvijezda može prikriti vanzemaljske signale"}],["$","div",null,{"className":"flex flex-wrap items-center gap-4 mb-6 text-sm text-text-secondary","children":[["$","div",null,{"className":"flex items-center gap-1","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-clock w-4 h-4","aria-hidden":"true","children":[["$","path","mmk7yg",{"d":"M12 6v6l4 2"}],["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],"$undefined"]}],["$","time",null,{"dateTime":"2026-03-11T12:00:00Z","children":"11. ožujka 2026."}],["$","span",null,{"className":"ml-1 opacity-60","children":["(","1w ago",")"]}]]}],["$","div",null,{"className":"flex items-center gap-1 text-accent-cyan/70","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-map-pin w-3 h-3","aria-hidden":"true","children":[["$","path","1r0f0z",{"d":"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"}],["$","circle","ilqhr7",{"cx":"1