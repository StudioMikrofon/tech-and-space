2:T41c,{"@context":"https://schema.org","@type":"NewsArticle","headline":"Kako razumijevanje može poboljšati ‘zaboravljanje’ AI modela","description":"Part 1: Kada govorimo o velikim jezikovnim modelima, riječ *zaboravljanje* ne podrazumijeva ljudski proces, nego **ciljano uklanjanje specifičnih informacija** iz pretreniranog modela — bez narušavanja njegove opće funkcionalnosti.","image":"https://techand.space/images/articles/reasoning-based-llm-unlearning-targets-model-safet/main.jpg","datePublished":"2026-03-12T12:00:00Z","dateModified":"2026-03-12T12:00:00Z","author":{"@type":"Organization","name":"Future Pulse","url":"https://futurepulse.hr"},"publisher":{"@type":"Organization","name":"TECH & SPACE","url":"https://techand.space","logo":{"@type":"ImageObject","url":"https://techand.space/logo.jpg"}},"mainEntityOfPage":{"@type":"WebPage","@id":"https://techand.space/article/space/2026-03-12-reasoning-based-llm-unlearning-targets-model-safet"},"inLanguage":"hr","articleSection":"space","keywords":"future-pulse, automated, space"}0:{"buildId":"8BczN53qI8xXbjPXJW-p6","rsc":["$","$1","c",{"children":[[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","$L3",null,{}],["$","article",null,{"className":"relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-6 sm:py-8","children":[["$","div",null,{"className":"flex items-center justify-between mb-6","children":[["$","$L4",null,{"href":"/hr","className":"inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left w-4 h-4","aria-hidden":"true","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Povratak"]}],["$","$L5",null,{"lang":"hr","