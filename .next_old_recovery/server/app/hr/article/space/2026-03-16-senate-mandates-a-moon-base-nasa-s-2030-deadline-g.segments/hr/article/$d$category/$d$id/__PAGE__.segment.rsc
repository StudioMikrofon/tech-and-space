ull,{"href":"","target":"_blank","rel":"noopener noreferrer","className":"flex items-center gap-1 hover:text-accent-cyan transition-colors","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-external-link w-3 h-3","aria-hidden":"true","children":["$L5","$L6","$L7","$undefined"]}],""]}]]}],"$L8","$undefined","$L9","$La","$Lb"]}],"$Lc"]}]]}]],["$Ld"],"$Le"]}],"loading":null,"isPartial":false}
